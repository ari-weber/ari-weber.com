---
interface FeaturedPhoto {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  photos: [FeaturedPhoto, FeaturedPhoto, FeaturedPhoto];
}

const { photos } = Astro.props;
const [main, ...secondary] = photos;
---

<div class="featured-grid">
  <!-- Large left image -->
  <figure class="featured-main scroll-reveal">
    <!-- new (main) -->
    <div class="featured-img-wrap">
      <button class="lb-trigger" data-lightbox-src={main.src} data-lightbox-alt={main.alt} aria-label={`View ${main.alt}`}>
        <img src={main.src} alt="" loading="lazy" decoding="async" />
      </button>
    </div>
    {main.caption && <figcaption class="featured-caption">{main.caption}</figcaption>}
  </figure>

  <!-- Right column: two stacked -->
  <div class="featured-secondary">
    {secondary.map((photo, i) => (
      <figure
        class="featured-sub scroll-reveal"
        style={`transition-delay: ${(i + 1) * 100}ms`}
      >
        <!-- new (secondary) -->
        <div class="featured-img-wrap">
          <button class="lb-trigger" data-lightbox-src={photo.src} data-lightbox-alt={photo.alt} aria-label={`View ${photo.alt}`}>
            <img src={photo.src} alt="" loading="lazy" decoding="async" />
          </button>
        </div>
        {photo.caption && <figcaption class="featured-caption">{photo.caption}</figcaption>}
      </figure>
    ))}
  </div>
</div>

<style>
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .featured-grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  figure {
    margin: 0;
    overflow: hidden;
    background: var(--bg-subtle);
    position: relative;
  }

  /* Remove grid-template-rows from .featured-secondary */
  .featured-secondary {
    display: grid;
    gap: var(--space-3);
    /* remove: grid-template-rows: 1fr 1fr */
  }

  .featured-img-wrap {
    overflow: hidden;
    width: 100%;
    height: 100%;
  }

  @media (min-width: 768px) {
  .featured-main .featured-img-wrap {
    /* was: aspect-ratio: unset; height: 100%; min-height: 480px; */
    /* remove entirely — natural height takes over */
  }
}

  /* Update img sizing */
  .featured-img-wrap img {
    width: 100%;
    height: auto;           /* was height: 100% */
    display: block;
    transition: transform var(--dur-slow) var(--ease-out);
    /* remove object-fit: cover */
  }

  .featured-main:hover img,
  .featured-sub:hover img {
    transform: scale(1.04);
  }

  .featured-caption {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    right: var(--space-4);
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.06em;
  }
  .lb-trigger {
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
</style>
